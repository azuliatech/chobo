// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url is supplied via prisma.config.ts (required by Prisma 7+)
}

// ──────────────────────────────────────────────
// USER
// ──────────────────────────────────────────────
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  phone           String?   @unique
  password        String?   // nullable for Google-only OAuth users
  name            String?
  countryCode     String    @default("NG")
  emailVerified   Boolean   @default(false)
  tosAccepted     Boolean   @default(false)
  expoPushToken   String?
  googleId        String?   @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  ownedWorkspaces  Workspace[]        @relation("WorkspaceOwner")
  memberships      WorkspaceMember[]
  staffSales       Sale[]             @relation("SaleStaff")
  notifications    Notification[]
  staffActivities  StaffActivity[]
}

// ──────────────────────────────────────────────
// WORKSPACE
// ──────────────────────────────────────────────
model Workspace {
  id            String    @id @default(uuid())
  name          String
  businessType  String?
  countryCode   String    @default("NG")
  tier          String    @default("FREE") // FREE | PRO | ENTERPRISE
  status        String    @default("ACTIVE") // ACTIVE | SUSPENDED
  ownerId       String
  owner         User      @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  members       WorkspaceMember[]
  products      UserProduct[]
  sales         Sale[]
  customers     Customer[]
  notifications Notification[]
  staffActivities StaffActivity[]

  @@index([ownerId])
}

// ──────────────────────────────────────────────
// WORKSPACE MEMBER
// ──────────────────────────────────────────────
model WorkspaceMember {
  id           String    @id @default(uuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId       String?                              // nullable — null until invited user completes signup
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  email        String                               // always present — used to match on signup
  role         String                               // OWNER | MANAGER | STAFF
  status       String    @default("PENDING")        // PENDING | ACTIVE | DECLINED | REMOVED
  inviteToken  String?   @unique                    // one-time use invite token
  inviteExpiry DateTime?                            // token expiry (7 days)
  createdAt    DateTime  @default(now())

  @@unique([workspaceId, email])                    // email is always present; replaces [workspaceId, userId]
  @@index([workspaceId])
  @@index([userId])
  @@index([inviteToken])
}

// ──────────────────────────────────────────────
// EMAIL VERIFICATION TOKENS
// ──────────────────────────────────────────────
model EmailVerification {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  code      String?
  type      String   @default("VERIFY") // VERIFY | RESET_PASSWORD
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// ──────────────────────────────────────────────
// PRODUCTS
// ──────────────────────────────────────────────
model UserProduct {
  id            String    @id @default(uuid())
  workspaceId   String
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  barcode       String?
  name          String
  sellingPrice  Float
  costPrice     Float?
  stock         Int       @default(0)
  imageUrl      String?
  category      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  saleItems     SaleItem[]

  @@index([workspaceId])
  @@index([workspaceId, barcode])
}

// ──────────────────────────────────────────────
// CUSTOMERS
// ──────────────────────────────────────────────
model Customer {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  phone       String?
  name        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sales       Sale[]
  debts       Debt[]

  @@index([workspaceId])
}

// ──────────────────────────────────────────────
// SALES
// ──────────────────────────────────────────────
model Sale {
  id             String     @id @default(uuid())
  workspaceId    String
  workspace      Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  staffId        String?    // which staff member made this sale
  staff          User?      @relation("SaleStaff", fields: [staffId], references: [id], onDelete: SetNull)
  total          Float
  discountAmount Float      @default(0)
  paymentType    String     // CASH | TRANSFER | POS | PAY_LATER
  timestamp      DateTime   @default(now())
  synced         Boolean    @default(true)
  customerId     String?
  customer       Customer?  @relation(fields: [customerId], references: [id])
  items          SaleItem[]
  payments       Payment[]
  debts          Debt[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([workspaceId])
  @@index([staffId])
  @@index([workspaceId, timestamp])
}

// ──────────────────────────────────────────────
// SALE ITEMS
// ──────────────────────────────────────────────
model SaleItem {
  id            String       @id @default(uuid())
  saleId        String
  sale          Sale         @relation(fields: [saleId], references: [id], onDelete: Cascade)
  userProductId String?
  userProduct   UserProduct? @relation(fields: [userProductId], references: [id], onDelete: SetNull)
  productName   String?      // snapshot at time of sale
  quantity      Int
  price         Float        // price at time of sale
}

// ──────────────────────────────────────────────
// PAYMENTS
// ──────────────────────────────────────────────
model Payment {
  id         String   @id @default(uuid())
  amount     Float
  senderName String?
  matched    Boolean  @default(false)
  saleId     String?
  sale       Sale?    @relation(fields: [saleId], references: [id])
  timestamp  DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ──────────────────────────────────────────────
// DEBTS
// ──────────────────────────────────────────────
model Debt {
  id         String    @id @default(uuid())
  customerId String
  customer   Customer  @relation(fields: [customerId], references: [id])
  amountOwed Float
  saleId     String?
  sale       Sale?     @relation(fields: [saleId], references: [id])
  status     String    @default("PENDING") // PENDING | PAID
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// ──────────────────────────────────────────────
// NOTIFICATIONS (now properly linked)
// ──────────────────────────────────────────────
model Notification {
  id          String     @id @default(uuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
  type        String     // SYSTEM | PAYMENT | LOW_STOCK | STAFF_ACTIVITY
  message     String
  read        Boolean    @default(false)
  timestamp   DateTime   @default(now())

  @@index([userId])
  @@index([workspaceId])
}

// ──────────────────────────────────────────────
// GLOBAL CATALOGUE (shared barcode database)
// ──────────────────────────────────────────────
model CatalogueProduct {
  barcode   String   @id
  name      String
  brand     String?
  imageUrl  String?
  category  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────
// STAFF ACTIVITY LOG
// ──────────────────────────────────────────────
model StaffActivity {
  id          String    @id @default(uuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String    // SALE_COMPLETED | PRODUCT_ADDED | STOCK_UPDATED | DISCOUNT_GIVEN | DEBT_CREATED | PAYMENT_LOGGED
  details     Json      // flexible metadata per action type
  createdAt   DateTime  @default(now())

  @@index([workspaceId, userId])
  @@index([workspaceId, createdAt])
}
